{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    }
  ],
  "env": {
    "JWT_SECRET": "@jwt-secret",
    "TWILIO_ACCOUNT_SID": "@twilio-account-sid",
    "TWILIO_AUTH_TOKEN": "@twilio-auth-token",
    "TWILIO_SERVICE_SID": "@twilio-service-sid",
    "REDIS_URL": "@redis-url",
    "MONGODB_URI": "@mongodb-uri"
  }
}